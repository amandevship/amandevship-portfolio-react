{
  "name": "server",
  "version": "1.0.0",
  "description": "Node.js API server with Express, MongoDB, and TypeScript",
  "main": "index.js",
  "packageManager": "yarn@4.6.0",
  "scripts": {
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:build\"",
    "dev:server": "nodemon --exec ts-node src/index.ts",
    "dev:build": "tsc --watch",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "author": "Aman Sharma",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-node": "^6.0.2",
    "typescript": "^6.0.2"
  }
}
